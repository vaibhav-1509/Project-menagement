# Copy this file to .env and fill in real values. .env itself should never be committed.
DB_SERVER=192.168.1.10
DB_PORT=1433
DB_NAME=ProjectManagement
DB_USER=
DB_PASSWORD=
DB_DRIVER=ODBC Driver 17 for SQL Server

JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=480

# Comma-separated list of frontend origins allowed to call the API (CORS)
CORS_ORIGINS_RAW=http://localhost:5173
